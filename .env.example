# Remnant frontend environment
# Copy to .env.local for local development. In production, set these in your
# hosting provider build/runtime environment.

# Public backend API URL. For launch this should be the AWS API domain.
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL. Usually the same as the API URL.
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Payment/escrow checkout is paused by default for launch.
NEXT_PUBLIC_ESCROW_ENABLED=false

# Search-engine ownership tokens. Enter only the token value, not the full meta tag.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Public ownership key used to notify Bing and other IndexNow search engines.
INDEXNOW_KEY=

# Do not put secrets in this file. NEXT_PUBLIC_* values are visible in browsers.
